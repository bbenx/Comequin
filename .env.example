# Copier vers .env (ne jamais committer .env)
# Clé API Anthropic — utilisée côté client (pour la prod, préférer une fonction serverless)
VITE_ANTHROPIC_API_KEY=

# OAuth Google — client de type « Application Web » (Google Cloud → APIs et services → Identifiants).
# Dans ce client, section « Origines JavaScript autorisées » : ajoutez CHAQUE URL où vous ouvrez l’app, par ex. :
#   http://localhost:5173
#   http://127.0.0.1:5173   (si vous utilisez 127.0.0.1 au lieu de localhost)
#   https://votre-app.vercel.app
# Sans l’origine exacte (y compris http vs https et le port), la connexion échoue sur cet appareil.
# API à activer : Gmail API. Scopes utilisés par l’app : envoi + paramètres d’envoi.
VITE_GOOGLE_CLIENT_ID=

# Copier vers .env (ne jamais committer .env)
# Clé API Anthropic — utilisée côté client (pour la prod, préférer une fonction serverless)
VITE_ANTHROPIC_API_KEY=

# OAuth Google (type Web application) — origines autorisées : http://localhost:5173, votre domaine Vercel
# Scopes à activer dans la console : Gmail API (envoi), People API ou userinfo si besoin
VITE_GOOGLE_CLIENT_ID=
